# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Build/Distribution
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/

# Local config
transcriptions.json

# Generated / local files (do not commit)
transcripts/
plans/
audio-checks/
audio_check_output.log
scratch/
training/

# Data sidecar repo — clone of github.com/teoperalez/resolve-mcp-data
# Contains snapshot of transcripts/ + plans/prompts/ so other machines
# can pull without re-transcribing. See README "Where transcripts and
# narrative plans live" section.
_data/

# Asset manifest lives globally at ~/.resolve-mcp/manifest.json (not in repo)
# Catalog (assets/catalog.json) IS committed — only ignore machine-local overrides
assets/manifest.json

.claude/*
!.claude/settings.json
!.claude/commands/
.claude/commands/*
!.claude/commands/*.md

# Blackmagic API reference (not ours to distribute)
README.txt

# Raw audio working files (large; regeneratable from source MP4 + transcripts)
*.wav

# Codex-sync runtime state (mailbox is committed for reference, runtime files are not)
.codex-sync/artifacts/
.codex-sync/status.json
.codex-sync/codex-stream.log
.codex-sync/codex-watcher-heartbeat.json
.codex-sync/codex-watcher-error.log
